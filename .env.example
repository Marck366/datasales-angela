# Frontend → API backend (FastAPI + MySQL)
VITE_API_BASE_URL="http://localhost:8000"


# AI
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Backend FastAPI + MySQL
DB_HOST="your-mysql-host"
DB_PORT="3306"
DB_NAME="your-database-name"
DB_USER="your-db-user"
DB_PASSWORD="your-db-password"
JWT_SECRET="generate-at-least-32-random-characters"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_HOURS="8"
ALLOWED_ORIGINS="http://localhost:5173,https://your-production-domain.com"
ALLOWED_HOSTS="localhost,127.0.0.1,your-production-domain.com"
LOG_HASH_SALT="generate-another-at-least-32-random-characters"
GLOBAL_RATE_LIMIT_PER_MINUTE="300"
AI_RATE_LIMIT_PER_MINUTE="20"
AI_PII_PROCESSING_ENABLED="false"

# Optional one-shot seed script. Never commit real users or passwords.
# SEED_INITIAL_PASSWORD="generate-a-temporary-password-with-16-plus-chars"
# SEED_USERS_JSON='[{"name":"Admin","email":"admin@example.com","role":"admin"}]'

# "development" (cookies sin Secure, /docs habilitado) o "production"
ENVIRONMENT="development"
